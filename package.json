{
  "name": "playwright-performance-metrics",
  "version": "1.2.6",
  "description": "A performance metrics collection library for Playwright",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "Readme.md"
  ],
  "scripts": {
    "\n========== Building ==========": "",
    "build": "tsc",
    "\n========== Testing ==========": "",
    "test": "playwright test",
    "lint": "eslint src/*.ts",
    "prepare": "npm run build",
    "\n========== Publishing ==========": "",
    "prepublishOnly": "npm test && npm run lint && npm run build",
    "publish": "npm publish",
    "publishd": "npm publish --dry-run",
    "preversion": "npm run lint",
    "version": "git add -A src",
    "postversion": "git push && git push --tags",
    "bump": "npx -y npm-check-updates -u && npm prune"
  },
  "keywords": [
    "playwright",
    "performance",
    "metrics",
    "web-vitals",
    "testing"
  ],
  "author": "Valentin Lutchanka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Valiantsin2021/playwright-performance-metrics.git"
  },
  "bugs": {
    "url": "https://github.com/Valiantsin2021/playwright-performance-metrics/issues"
  },
  "homepage": "https://github.com/Valiantsin2021/playwright-performance-metrics#readme",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "src/*.+(cjs|js|ts|tsx)": [
      "eslint src/*.ts"
    ],
    "**/*.+(cjs|js|ts|json)": [
      "prettier --cache --write",
      "git add"
    ]
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0 <2.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "25.5.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "prettier": "3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
